:false,"max":null,"min":null,"datetime_format":null,"set_to_current_datetime":false,"possible_answers":[],"jumps":[],"branch":[],"group":[{"ref":"946be735ead74d1b928ad7e083a91b82_67293ee17554a_67fe474a32348_67fe499c3234a","type":"readme","question":"&lt;p data-start=&quot;184&quot; data-end=&quot;489&quot; class=&quot;&quot;&gt;Las redes comunitarias son &lt;strong data-start=&quot;211&quot; data-end=&quot;249&quot;&gt;grupos organizados de la comunidad&lt;/strong&gt; que participan activamente en procesos sociales, educativos y de salud. Incluyen colectivos como &lt;strong data-start=&quot;347&quot; data-end=&quot;473&quot;&gt;madres líderes, juntas de acción comunal (JAC), promotores de salud, cuidadores, asociaciones de víctimas, redes juveniles&lt;/strong&gt;, entre otros.&lt;/p&gt;&lt;p&gt;\n&lt;/p&gt;&lt;p data-start=&quot;496&quot; data-end=&quot;772&quot; class=&quot;&quot;&gt;Esta sección permite registrar las &lt;strong data-start=&quot;531&quot; data-end=&quot;565&quot;&gt;acciones de educación en salud&lt;/strong&gt; realizadas por el equipo APS a estas redes, en el marco de la promoción de la salud, la participación social y la gestión comunitaria del riesgo, conforme a lo establecido en la &lt;strong data-start=&quot;744&quot; data-end=&quot;771&quot;&gt;Resolución 3280 de 2018&lt;/strong&gt;.&lt;/p&gt;","is_title":false,"is_required":false,"uniqueness":"none","regex":null,"default":null,"verify":false,"max":null,"min":null,"datetime_format":null,"set_to_current_datetime":false,"possible_answers":[],"jumps":[],"branch":[],"group":[]},{"ref":"946be735ead74d1b928ad7e083a91b82_67293ee17554a_67fe474a32348_67fe49d23234b","type":"checkbox","question":"7. Curso de Vida y Promoción de la Salud","is_title":false,"is_required":true,"uniqueness":"none","regex":null,"default":"","verify":false,"max":null,"min":null,"datetime_format":null,"set_to_current_datetime":false,"possible_answers":[{"answer":"Cuidado en la primera infancia","answer_ref":"67fe49d23234c"},{"a